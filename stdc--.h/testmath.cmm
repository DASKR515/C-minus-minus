export main;

main() {
    float64 r;
    float64 fx; 
    float64 fy; 
    W_ li;
    bits32 ilg;


    float64 v0, v1, v2, v3, v4, v4_3, v4_5, v4_7, v5, v5_5, v7, v8, v9, v10, v27, v1000, v2_718;
    v0 = float64[k0];
    v1 = float64[k1];
    v2 = float64[k2];
    v3 = float64[k3];
    v4 = float64[k4];
    v4_3 = float64[k4_3];
    v4_5 = float64[k4_5];
    v4_7 = float64[k4_7];
    v5 = float64[k5];
    v5_5 = float64[k5_5];
    v7 = float64[k7];
    v8 = float64[k8];
    v9 = float64[k9];
    v10 = float64[k10];
    v27 = float64[k27];
    v1000 = float64[k1000];
    v2_718 = float64[k2_718];

    (r) = foreign "C" sqrt(v9);
    moutf(l01 "ptr", r);

    (r) = foreign "C" cbrt(v27);
    moutf(l02 "ptr", r);

    (r) = foreign "C" pow(v2, v10);
    moutf(l03 "ptr", r);

    (r) = foreign "C" exp(v1);
    moutf(l04 "ptr", r);

    (r) = foreign "C" exp2(v3);
    moutf(l05 "ptr", r);

    (r) = foreign "C" expm1(v1);
    moutf(l06 "ptr", r);

    (r) = foreign "C" log(v2_718);
    moutf(l07 "ptr", r);

    (r) = foreign "C" log2(v8);
    moutf(l08 "ptr", r);

    (r) = foreign "C" log10(v1000);
    moutf(l09 "ptr", r);

    (r) = foreign "C" log1p(v0);
    moutf(l10 "ptr", r);

    (r) = foreign "C" fabs(v5_5);
    moutf(l11 "ptr", r);

    (r) = foreign "C" fmod(v10, v3);
    moutf(l12 "ptr", r);

    (r) = foreign "C" remainder(v10, v3);
    moutf(l13 "ptr", r);

    (r) = foreign "C" fmax(v3, v7);
    moutf(l14 "ptr", r);

    (r) = foreign "C" fmin(v3, v7);
    moutf(l15 "ptr", r);

    (r) = foreign "C" fdim(v7, v3);
    moutf(l16 "ptr", r);

    (r) = foreign "C" hypot(v3, v4);
    moutf(l17 "ptr", r);

    (r) = foreign "C" ceil(v4_3);
