    (r) = foreign "C" tgamma(v5);
    moutf(l51 "ptr", r);

    (r) = foreign "C" erf(v1);
    moutf(l52 "ptr", r);

    (r) = foreign "C" erfc(v1);
    moutf(l53 "ptr", r);

    mout(hdr "ptr");

    r = float64[val_pi];
    moutf(lc1 "ptr", r);

    r = float64[val_e];
    moutf(lc2 "ptr", r);

    r = float64[val_sqrt2];
    moutf(lc3 "ptr", r);

    return (0);
