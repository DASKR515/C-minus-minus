    (r) = foreign "C" floor(v4_7);
    moutf(l19 "ptr", r);

    (r) = foreign "C" trunc(v4_7);
    moutf(l20 "ptr", r);

    (r) = foreign "C" round(v4_5);
    moutf(l21 "ptr", r);

    fx = v4_5;
    (li) = foreign "C" lround(fx);
    moutf(l22 "ptr", li);

    (li) = foreign "C" llround(fx);
    moutf(l23 "ptr", li);

    (r) = foreign "C" rint(fx);
    moutf(l24 "ptr", r);

    (r) = foreign "C" nearbyint(fx);
    moutf(l25 "ptr", r);

    (li) = foreign "C" lrint(fx);
    moutf(l26 "ptr", li);

    (li) = foreign "C" llrint(fx);
    moutf(l27 "ptr", li);

    fy = float64[kneg1];
    (r) = foreign "C" copysign(v3, fy);
    moutf(l28 "ptr", r);

    (r) = foreign "C" nan(nan_tag "ptr");
    moutf(l29 "ptr", r);

    (r) = foreign "C" sin(v0);
    moutf(l30 "ptr", r);

    (r) = foreign "C" cos(v0);
    moutf(l31 "ptr", r);

    (r) = foreign "C" tan(v0);
    moutf(l32 "ptr", r);

    (r) = foreign "C" asin(v1);
    moutf(l33 "ptr", r);

    (r) = foreign "C" acos(v1);
    moutf(l34 "ptr", r);

    (r) = foreign "C" atan(v1);
    moutf(l35 "ptr", r);

    (r) = foreign "C" atan2(v1, v1);
    moutf(l36 "ptr", r);

    (r) = foreign "C" sinh(v0);
    moutf(l37 "ptr", r);

    (r) = foreign "C" cosh(v0);
    moutf(l38 "ptr", r);

    (r) = foreign "C" tanh(v0);
    moutf(l39 "ptr", r);

    (r) = foreign "C" asinh(v0);
    moutf(l40 "ptr", r);

    (r) = foreign "C" acosh(v1);
    moutf(l41 "ptr", r);

    (r) = foreign "C" atanh(v0);
    moutf(l42 "ptr", r);

    W_ ptr_e;
    ptr_e = e_out;
    (r) = foreign "C" frexp(v8, ptr_e);
    ilg = bits32[ptr_e]; 
    moutf(l43 "ptr", r, ilg);

    (r) = foreign "C" ldexp(v1, 3);
    moutf(l44 "ptr", r);

    W_ ptr_ip;
    ptr_ip = ip_out;
    fy = float64[k3_75];
    (r) = foreign "C" modf(fy, ptr_ip);
    fy = float64[ptr_ip];
    moutf(l45 "ptr", r, fy);

    (r) = foreign "C" scalbn(v1, 4);
    moutf(l46 "ptr", r);

    (r) = foreign "C" scalbln(v1, 4);
    moutf(l47 "ptr", r);

    (ilg) = foreign "C" ilogb(v8);
    moutf(l48 "ptr", ilg);

