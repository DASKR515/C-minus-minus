#include "Cmm.h"
#include "stdc--.h"

//data
section "data" { fmt: bits8[] "%d\0"; }
section "data" { tag1: bits8[] "Enter First Mark\n\0"; }
section "data" { tag2: bits8[] "Enter Second Mark\n\0"; }
section "data" { tag3: bits8[] "Enter Third Mark\n\0"; }
//bss
section "bss" { num_1: bits64; }
section "bss" { num_3: bits64; }
section "bss" { num_2: bits64; }

export Winmain;
export main;


Winmain(){
	jump main[];
}

main(){
        W_ num1;
        W_ num3;
        W_ num2;
        min(tag1, "ptr", num_1, "ptr");
        min(tag2, "ptr", num_2, "ptr");
        min(tag3, "ptr", num_3, "ptr");
        num1 = bits64[tag1];
        num2 = bits64[tag2];
        num3 = bits64[tag3];
        moutf(fmt, "ptr", num1);
        moutf(fmt, "ptr", num2);
        moutf(fmt, "ptr", num3);
        mexit(0);
}
