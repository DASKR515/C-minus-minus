#include "Cmm.h"
#include "stdc--.h"
#include "cmmath.h"

section "bss" { x: bits64; }
section "bss" { frac: bits64; }
section "bss" { integer: bits64; }

section "data" { s1: bits8[] "5.5\0"; }
section "data" { fmt1: bits8[] "fractional = %f\n\0"; }
section "data" { fmt2: bits8[] "integer = %f\n\0"; }

export main;

main() {
    float64 f, i;

    foreign "C" testx(x, s1 "ptr");

    mmodf(frac, integer, x);

    f = float64[frac];
    i = float64[integer];

    moutf(fmt1 "ptr", f);
    moutf(fmt2 "ptr", i);

    mexit(0);
}
